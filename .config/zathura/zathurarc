# Misc
set guioptions s
set statusbar-home-tilde true
set selection-clipboard clipboard
set adjust-open width
set recolor-reverse-video false
set incremental-search false
set font "JetBrains Mono 10"

# Keybinds
map \< goto top
map \> goto bottom
map b navigate previous
map e follow
map f navigate next
map p goto top
map [normal]     <C-l> reload
map [fullscreen] <C-l> reload
map <C-+> zoom in
map <C--> zoom out
map <C-=> zoom in
map <C-)> adjust_window best-fit
map <C-0> adjust_window width
map <C-a> scroll full-left
map <C-b> scroll left
map [normal]     e scroll full-right
map [fullscreen] e scroll full-right
map <C-e> scroll full-right
map <C-f> scroll right
map <C-g> abort
map <C-n> scroll down
map <C-p> scroll up
map <C-v> scroll full-down
map [normal]     <C-e> scroll down
map [fullscreen] <C-e> scroll down
map [normal]     y scroll up
map [fullscreen] y scroll up
map [normal]     <C-y> scroll up
map [fullscreen] <C-y> scroll up
map <A-\<> goto top
map <A-\>> goto bottom
map <A-v> scroll full-up

unmap d
unmap u
map d scroll half-down
map u scroll half-up

# Show only the file name in the window title.
set window-title-basename true

# Theme colors (loaded from symlink managed by toggle-theme.sh)
include colors
